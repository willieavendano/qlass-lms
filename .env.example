# =============================================================================
# Qlass — Environment variables
# =============================================================================
# Copy for local development (use BOTH — Prisma only reads .env by default):
#   cp .env.example .env
#   cp .env.example .env.local
#
# Or symlink:  ln -sf .env.local .env
#
# Never commit .env, .env.local, or real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Local (docker compose):  docker compose up postgres -d
DATABASE_URL="postgresql://qlass:qlass@localhost:5432/qlass?schema=public"

# NextAuth — must match your app URL
NEXTAUTH_URL="http://localhost:3000"

# Secret for signing sessions/tokens (required)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# OAuth providers (optional — leave blank to disable)
# -----------------------------------------------------------------------------

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Google Classroom import
# -----------------------------------------------------------------------------
# Keyless demo mode: when "true", the "Import from Google Classroom" flow uses
# built-in sample courses (no Google credentials/OAuth needed) and creates real
# classes in the DB. Leave blank/false for the real Google-backed import.
CLASSROOM_DEMO_MODE="false"

# GitHub: Settings → Developer settings → OAuth Apps
GITHUB_ID=""
GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# File storage
# -----------------------------------------------------------------------------
# Options: local | s3 | supabase

STORAGE_PROVIDER="local"

# --- local (default) ---
UPLOAD_DIR="./uploads"

# --- AWS S3 (STORAGE_PROVIDER=s3) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="qlass-uploads"

# --- Supabase Storage (STORAGE_PROVIDER=supabase) ---
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="qlass-uploads"

# -----------------------------------------------------------------------------
# Email (optional — for digests & notifications)
# -----------------------------------------------------------------------------

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@qlass.local"

# -----------------------------------------------------------------------------
# Node / Next.js (usually set automatically)
# -----------------------------------------------------------------------------

# NODE_ENV=development
# PORT=3000

# -----------------------------------------------------------------------------
# Docker Compose reference (app service uses these internally)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://qlass:qlass@postgres:5432/qlass?schema=public
# NEXTAUTH_URL=http://localhost:3000
