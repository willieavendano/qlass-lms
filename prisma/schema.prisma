generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  ADMIN
  TEACHER
  STUDENT
  GUARDIAN
}

enum ClassRole {
  OWNER
  TEACHER
  STUDENT
  GUARDIAN
}

enum JoinPermission {
  ANYONE_WITH_CODE
  APPROVAL_REQUIRED
  INVITE_ONLY
}

enum PostType {
  ANNOUNCEMENT
  MATERIAL
  ASSIGNMENT
  QUESTION
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  ASSIGNED
  TURNED_IN
  GRADED
  RETURNED
}

enum NotificationType {
  ANNOUNCEMENT
  ASSIGNMENT_DUE
  GRADE_POSTED
  COMMENT
  INVITE
  SYSTEM
}

enum EmailDigest {
  IMMEDIATE
  DAILY
  OFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  systemRole    SystemRole @default(STUDENT)
  suspended     Boolean   @default(false)
  emailDigest   EmailDigest @default(DAILY)
  digestSentAt  DateTime?
  googleUserId  String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   ClassMembership[]
  posts         Post[]           @relation("PostAuthor")
  submissions   Submission[]
  gradesGiven   Grade[]          @relation("GradedBy")
  comments      Comment[]
  notifications Notification[]
  attachments   Attachment[]     @relation("UploadedBy")
  aiSetting     UserAiSetting?
  agentRuns     AgentRun[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Class {
  id              String         @id @default(cuid())
  name            String
  section         String?
  description     String?        @db.Text
  joinCode        String         @unique
  bannerColor     String         @default("#0d9488")
  bannerImageKey  String?
  archived        Boolean        @default(false)
  joinPermission  JoinPermission @default(ANYONE_WITH_CODE)
  notificationsOn Boolean        @default(true)
  googleCourseId  String?        @unique
  ownerId         String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  memberships  ClassMembership[]
  posts        Post[]
  categories   AssignmentCategory[]
  courseMemory CourseMemory?
  agentRuns    AgentRun[]
}

model ClassMembership {
  id        String    @id @default(cuid())
  classId   String
  userId    String
  role      ClassRole @default(STUDENT)
  muted     Boolean   @default(false)
  joinedAt  DateTime  @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([userId])
}

model AssignmentCategory {
  id            String  @id @default(cuid())
  classId       String
  name          String
  order         Int     @default(0)
  googleTopicId String?

  class Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([classId, googleTopicId])
}

model Post {
  id          String     @id @default(cuid())
  classId     String
  authorId    String
  type        PostType
  status      PostStatus @default(DRAFT)
  title       String
  content     String?    @db.Text
  categoryId  String?
  dueDate     DateTime?
  points      Int?
  youtubeUrl  String?
  linkUrl     String?
  aiGenerated Boolean    @default(false)
  publishedAt DateTime?
  googleCourseWorkId   String? @unique
  googleAnnouncementId String? @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  class       Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  author      User                @relation("PostAuthor", fields: [authorId], references: [id])
  category    AssignmentCategory? @relation(fields: [categoryId], references: [id])
  assignment  Assignment?
  question    Question?
  comments    Comment[]
  attachments Attachment[]

  @@index([classId, type, status])
}

model Assignment {
  id          String  @id @default(cuid())
  postId      String  @unique
  instructions String? @db.Text
  allowLate   Boolean @default(true)
  rubricId    String?

  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  rubric Rubric? @relation(fields: [rubricId], references: [id])
  submissions Submission[]
}

model Question {
  id            String @id @default(cuid())
  postId        String @unique
  questionType  String @default("SHORT_ANSWER")
  options       Json?
  correctAnswer String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Rubric {
  id          String @id @default(cuid())
  title       String
  criteria    Json
  createdAt   DateTime @default(now())

  assignments Assignment[]
}

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  status        SubmissionStatus @default(ASSIGNED)
  textResponse  String?          @db.Text
  linkUrl       String?
  turnedInAt    DateTime?
  isLate        Boolean          @default(false)
  googleSubmissionId String?     @unique
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])
  grade      Grade?
  attachments Attachment[]

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
}

model Grade {
  id            String   @id @default(cuid())
  submissionId  String   @unique
  graderId      String
  points        Float?
  maxPoints     Float?
  feedback      String?  @db.Text
  privateComment String? @db.Text
  returnedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  grader     User       @relation("GradedBy", fields: [graderId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String   @db.Text
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  mimeType     String
  size         Int
  storageKey   String
  uploaderId   String
  postId       String?
  submissionId String?
  googleMaterialId String?
  driveFileId  String?
  createdAt    DateTime @default(now())

  uploader   User        @relation("UploadedBy", fields: [uploaderId], references: [id])
  post       Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model SystemSettings {
  id              String  @id @default("default")
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpFrom        String?
  storageProvider String  @default("local")
  s3Bucket        String?
  s3Region        String?
  aiProvider      String?
  aiBaseUrl       String?
  aiModel         String?
  aiApiKeyEnc     String?  @db.Text
  aiWebSearch     Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model CourseMemory {
  id         String   @id @default(cuid())
  classId    String   @unique
  subject    String?
  gradeLevel String?
  standards  String?  @db.Text
  summary    String?  @db.Text
  facts      Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id        String   @id @default(cuid())
  classId   String
  userId    String
  kind      String   @default("UNIT_BUILD")
  status    String   @default("PENDING")
  input     Json
  outline   Json?
  drafts    Json?
  review    Json?
  model     String?
  error     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([classId])
}

model UserAiSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  provider  String
  baseUrl   String?
  model     String?
  apiKeyEnc String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
